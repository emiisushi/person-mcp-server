# Database (use Neon, Supabase, or Vercel Postgres for production)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Public base URL of the deployed app (used by MCP server)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: shared secret to protect write operations from the MCP server
MCP_API_KEY="change-me-to-a-long-random-string"
